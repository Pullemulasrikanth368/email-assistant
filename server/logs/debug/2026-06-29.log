for windows phone-->\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\"/>\r\n    <style>\r\n        .dueDate {\r\n            font-weight: bold;\r\n            color: #F8981D;\r\n        }\r\n    </style>\r\n</head>\r\n\r\n<body style=\"margin-top:0; padding:0; margin:0; background-color:rgb(240 240 240);\">\r\n<div style=\"display:none;font-size:1px;line-height:1px;max-height:0px;max-width:0px;opacity:0;overflow:hidden;mso-hide:all;font-family: sans-serif;\">\r\n    Hi Deva, Your Amazon Pay ICICI Bank Credit Card bill payment is due on 30 Jun 2026\r\n</div>\r\n<div style=\"margin-top:0; padding:0; margin:0; background-color:rgb(240 240 240);\">\r\n    <table\r\n            style=\"width:100%!important;table-layout:fixed;border-collapse:collapse;font-family:'Amazon Ember, Arial, Helvetica, sans-serif;border-spacing:0;background-color: rgb(246 246 246);\"\r\n            width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\r\n        <tbody>\r\n        <tr>\r\n            <td align=\"center\" style=\"margin-top:0; background-color: rgb(240 240 240);\">\r\n                <table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"\r\n                       style=\"max-width: 450px; border-spacing:0; background-color:rgb(255,255,255);border: 1px solid rgb(240 240 240);\">\r\n                    <tbody>\r\n                    <tr>\r\n                        <td align=\"center\">\r\n                            <table class=\"content-shell-table\" width=\"100%\" border=\"0\" cellpadding=\"0\"\r\n                                   cellspacing=\"0\" style=\"max-width: 450px; border-spacing:0;border-top: 5px solid #eda039;\">\r\n                                <tbody>\r\n                                <tr>\r\n                                    <td style=\"border-collapse:collapse\">\r\n                                        <!-- Apay Logo Table -->\r\n                                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\"\r\n                                               style=\"border-spacing:0\" width=\"100%\"\r\n                                               style=\"width:100%; border-spacing:0\">\r\n                                            <tbody>\r\n                                            <tr>\r\n                                                <td align=\"left\"\r\n                                                    style=\"padding-left: 10px;padding-right: 20px;padding-top:20px;text-align:left;\">\r\n                                                    <a href=\"https://www.amazon.in/amazonpay/home?ref_=email_p2p_dasp\"\r\n                                                       target=\"_blank\" rel=\"noreferrer\"\r\n                                                       style=\"color:inherit\">\r\n                                                        <img src=\"https://m.media-amazon.com/images/G/31/AP4/Notifications/ApayLogoWhiteBG.jpg\"\r\n                                                             alt=\"\" width=\"200\" border=\"0\"\r\n                                                             style=\"border:none; outline:none; border-collapse:collapse; border-style:none\">\r\n                                                    </a>\r\n                                                </td>\r\n                                            </tr>\r\n                                            </tbody>\r\n                                        </table>\r\n                                        <!-- Apay Logo Table ends -->\r\n                                    </td>\r\n                                </tr>\r\n                                <tr>\r\n                                    <td style=\"border-collapse:collapse\">\r\n                                        <!-- Intro Text table -->\r\n                                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\"\r\n                                               style=\"border-spacing