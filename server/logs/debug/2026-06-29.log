now. Thank you once again for your support and for helping us keep our account secure.</p>\n\n<p>Best regards,</p>\n\n<p><strong>Office of the VP, Manufacturing Operations</strong></p>","cc":[],"createdAt":"2026-06-29T09:15:01.819Z","email":"chandu767p@gmail.com","from":"Chandu P <chandu767p@gmail.com>","hasAttachments":false,"intent":"fyi","isRepliedMail":true,"labels":["SENT"],"mimeType":"text/html","prioritizedAt":"2026-06-29T09:15:05.163Z","priority":"Low","priorityReason":"Security issue has been addressed and no further action is required.","priorityScore":10,"provider":"gmail","providerMessageId":"19f12a435f0c8cc5","receivedAt":"2026-06-29T09:09:39.000Z","removedAt":null,"removedReason":null,"replyTo":"","snippet":"Dear Google Security Team, Thank you for your prompt notification regarding the access given to the application &quot;emailsummarizers&quot; for our Google Account associated with chandu767p@gmail.com.","subject":"Re: Security alert","threadId":"19f1257837791a61","to":"Google <no-reply@accounts.google.com>","updatedAt":"2026-06-29T09:15:05.164Z"}},"statusCode":200},"responseTime":9}}
