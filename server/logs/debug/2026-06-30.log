\n.button:hover { background-color: #8019F5 !important; color: #FFFFFF !important; border-color: #8019F5 !important }\r\n.button--green:hover { background-color: #22BC66 !important }\r\n.button--red:hover { background-color: #FF6136 !important }</style>\r\n  </head>\r\n  <body style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; height: 100%; margin: 0; line-height: 1.4; color: #000000; background-color: #FFFFFF; -webkit-text-size-adjust: none; width: 100% !important;\">\r\n    <span class=\"preheader\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; visibility: hidden; mso-hide: all; font-size: 1px; line-height: 1px; max-height: 0; max-width: 0; opacity: 0; overflow: hidden; display: none !important;\"></span>\r\n    <table class=\"email-wrapper\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; width: 100%; margin: 0; padding: 0; -premailer-width: 100%; -premailer-cellpadding: 0; -premailer-cellspacing: 0;\">\r\n      <tbody style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box;\"><tr>\r\n        <td align=\"center\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box;\">\r\n          <table class=\"email-masthead\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; width: 100%; margin: 0; padding: 0; -premailer-width: 100%; -premailer-cellpadding: 0; -premailer-cellspacing: 0; text-align: center;\">\r\n            <tbody style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box;\"><tr>\r\n              <td class=\"email-masthead\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; width: 100%; margin: 0; padding: 0; -premailer-width: 100%; -premailer-cellpadding: 0; -premailer-cellspacing: 0; text-align: center;\">\r\n                <a href=\"https://render.com/\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; color: #9568F7; font-weight: bold;\"><img src=\"https://render.com/images/render-header-dark.png\" alt=\"Render\" style=\"width: 100%; max-width: 570px; height: auto; font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; border: none;\"></a>\r\n              </td>\r\n            </tr>\r\n            <!-- Email Body -->\r\n            <tr>\r\n              <td class=\"email-body\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; width: 100%; margin: 0; padding: 0; -premailer-width: 100%; -premailer-cellpadding: 0; -premailer-cellspacing: 0; border-bottom: 1px solid #EDEFF2; background-color: #FFFFFF;\">\r\n                <table class=\"email-body_inner\" align=\"center\" width=\"570\" cellpadding=\"0\" cellspacing=\"0\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; width: 570px; margin: 0 auto; padding: 0; -premailer-width: 570px; -premailer-cellpadding: 0; -premailer-cellspacing: 0; background-color: #FFFFFF;\">\r\n                  <!-- Body content -->\r\n                  <tbody style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box;\"><tr>\r\n                    <td class=\"content-cell\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; padding: 35px;\">\r\n                      <p style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; line-height: 1.5em; text-align: left; color: #000000; font-size: 16px; margin-top: 0; margin-bottom: 15px;\">We recently detected a server failure for <a href=\"https://dashboard.render.com/web/srv-d7cdnureo5us73e3lav0\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; color: #9568F7; font-weight: bold;\">HOTEL_POS_API</a>:</p>\r\n<p class=\"error-reason\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; line-height: 1.5em; text-align: left; color: #000000; font-size: 14px; margin-top: 20px; margin-bottom: 20px; padding-left: 20px;\"><strong style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box;\">Exited with status 1</strong></p>\r\n\r\n<p style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; line-height: 1.5em; text-align: left; color: #000000; font-size: 16px; margin-top: 0; margin-bottom: 15px;\">This alert means one of the instances running your service became unavailable. <b style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box;\">In many cases, this issue resolves automatically.</b>\r\n</p>\r\n  <ul style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; line-height: 1.4; text-align: left; list-style-type: square; padding-left: 15px;\">\r\n    <li style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; color: #000000; font-size: 16px; line-height: 1.5em; text-align: left; margin-top: 10px;\">If your service has multiple instances, traffic may have continued uninterrupted.</li>\r\n    <li style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; color: #000000; font-size: 16px; line-height: 1.5em; text-align: left; margin-top: 10px;\">Render may have already restarted or replaced the affected instance automatically.</li>\r\n  </ul>\r\n  \r\n  <h2 style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; margin-top: 25px; margin-bottom: 16px; color: #000000; font-size: 20px; font-weight: bold; text-align: left;\">Recommended next steps:</h2>\r\n    <ul style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; line-height: 1.4; text-align: left; list-style-type: square; padding-left: 15px;\">\r\n    <li style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; color: #000000; font-size: 16px; line-height: 1.5em; text-align: left; margin-top: 10px;\">Review your recent <a href=\"https://dashboard.render.com/web/srv-d7cdnureo5us73e3lav0/logs\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; color: #9568F7; font-weight: bold;\">logs</a></li>\r\n    <li style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; color: #000000; font-size: 16px; line-height: 1.5em; text-align: left; margin-top: 10px;\">Read our <a href=\"https://render.com/docs/uptime-best-practices\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; color: #9568F7; font-weight: bold;\">uptime best practices</a></li>\r\n  </ul>\r\n\r\n<p style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; line-height: 1.5em; text-align: left; color: #000000; font-size: 16px; margin-top: 0; margin-bottom: 15px;\">\r\nThe Render Team\r\n</p>\r\n\r\n<p class=\"sub\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; line-height: 1.3; text-align: left; color: #000000; font-size: 12px; margin-top: 0; margin-bottom: 15px;\">Don't want to receive these emails? You can change your notification settings for <a href=\"https://dashboard.render.com/t/tea-d7cdhld8nd3s73fc25ug/settings#notifications\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; color: #9568F7; font-weight: bold;\">your workspace</a> or <a href=\"https://dashboard.render.com/web/srv-d7cdnureo5us73e3lav0/settings#notifications\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; color: #9568F7; font-weight: bold;\">just this service</a>.</p>\r\n\r\n<p class=\"sub\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; line-height: 1.3; text-align: left; color: #000000; font-size: 12px; margin-top: 0; margin-bottom: 15px;\">Need more help? <a href=\"https://dashboard.render.com/?contact-support}\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; color: #9568F7; font-weight: bold;\">Contact</a> our Support team.</p>\r\n\r\n\r\n                      <!-- Sub copy -->\r\n                      <table width=\"100%\" class=\"body-sub\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; margin-top: 25px; padding-top: 25px; border-top: 1px solid #EDEFF2;\">\r\n                        <tbody style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box;\"><tr>\r\n                          <td class=\"content-cell\" align=\"center\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; padding: 35px;\">\r\n                            <p class=\"sub align-center\" style=\"font-family: &quot;Helvetica Neue&quot;, Arial, Helvetica, sans-serif; box-sizing: border-box; line-height: 1.3; text-align: center; color: #000000; font-size: 12px; margin-top: 0; margin-bottom: 15px;\">© 2026 Render, 525 Brannan St #300, San Francisco, CA 94107</p>\r\n                          </td>\r\n                        </tr>\r\n                      </tbody></table>\r\n                    </td>\r\n                  </tr>\r\n                </tbody></table>\r\n              </td>\r\n            </tr>\r\n          </tbody></table>\r\n        </td>\r\n      </tr>\r\n    </tbody></table>\r\n  \r\n<img src=\"https://ea.pstmrk.it/open?m=v3_1.r4txHR-lu64MNAYgNrsCPg.3z8AFd8YdVh7wXwK24D_4IzVddEawWTYW8QcstTyYp8xbfTQp8_EuRr1qnpndBb3Rfh1HAUfhBu1vW9X4yzgydR34pO--9PgrnMqmgHmuAC7sTo-gLwCy-L2_sTJRq3wgw1NCzM9kggOZ_q1ke0My6f9PqZ-YPVe2QsTLfNxRieavtX_mAxVU3BNmOIJuOQXzAZovmzi6JSM2foaCJ6w7Txor5_4coDfYzf4aGcZ6G-cbMJqoJ9mXDjYZ6yv2X51HJYRr0chm0gNepgpSyHgt5lappXwEgMYh0ktI-WGTNlWth5WtSYKX6-IaSSK_pfGEJBsqgIJYfZMQb9NnsJV-73gd5MMNTE41WXNVlzCGcbKEfaq6e-_9hYf6oh_4SmEpEo6EHL36qY9Q677A3fGlqnH31tfHKJwnatH72zxfyr9SzXf_XMc49QHFl1_UCd2ccXQ7dMu_0dk20fR7S1jMSPmFSa-7QkZiQfRr-jXVSSm0NcFevKwyVI3LvsG8AIQyOGxsE9bCjgZYppLVYRN9A\" width=\"1\" height=\"1\" border=\"0\" alt=\"\" /></body></html>\r\n","cc":[],"createdAt":"2026-06-29T18:00:03.185Z","email":"chandu767p@gmail.com","from":"Render <no-reply@render.com>","hasAttachments":false,"intent":"escalation","isRepliedMail":false,"labels":["UNREAD","CATEGORY_UPDATES","INBOX"],"mimeType":"multipart/alternative","prioritizedAt":"2026-06-29T18:00:06.887Z","priority":"Critical","priorityReason":"Server failure detected, potential impact on service availability, immediate review suggested.","priorityScore":90,"provider":"gmail","providerMessageId":"19f147cd10c1e53e","receivedAt":"2026-06-29T17:45:51.000Z","removedAt":null,"removedReason":null,"replyTo":"","snippet":"Render We recently detected a server failure for HOTEL_POS_API: Exited with status 1 This alert means one of the instances running your service became unavailable. In many cases, this issue resolves","subject":"Server failure detected on HOTEL_POS_API","threadId":"19f147cd10c1e53e","to":"chandu767p@gmail.com","updatedAt":"2026-06-29T18:00:06.888Z"}},"statusCode":200},"responseTime":7}}
